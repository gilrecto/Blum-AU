{% liquid
	assign image = image
	assign widths = '[540, 720, 900, 1080, 1296, 1512, 1728, 1944, 2048]'
	assign image_class = 'Image--lazyLoad lazyload img-fluid lazy2'
	assign fetch_priority = 'auto'

	if class != blank
		assign image_class = image_class | append: ' '| append: class
	endif
  
   if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

<img class="{{ image_class }}"
     fetchpriority="{{ fetch_priority }}"
     srcset="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" 
     data-widths="{{ widths }}"
     data-aspectratio="{{ image.aspect_ratio }}"
     data-sizes="auto"
     data-parent-fit="cover"
     alt="{{ image.alt | escape }}"
     data-src="{{ image | image_url: width: 400 }}"
     data-srcset="{{ image | image_url: width: 400 }} 360w,
                  {{ image | image_url: width: 540 }} 540w,
                  {{ image | image_url: width: 720 }} 720w,
                  {{ image | image_url: width: 900 }} 900w,
                  {{ image | image_url: width: 1600 }} 1600w,
                  {{ image | image_url: width: 1900 }} 1900w"
     width="{{ image.width }}"
     height="{{ image.height }}"
     loading="lazy"
     style="aspect-ratio: {{ image.aspect_ratio }};">