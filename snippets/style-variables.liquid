{%- liquid
	assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
	assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
	assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
	assign heading_font_bold = settings.type_header_font | font_modify: 'weight', 'bold'
-%}

{%- if settings.type_body_font != blank -%}
	<link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
{%- endif -%}
{%- if body_font_bold != blank -%}
	<link rel="preload" as="font" href="{{ body_font_bold | font_url }}" type="font/woff2" crossorigin>
{%- endif -%}
{%- if settings.type_header_font != blank -%}
	<link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
{%- endif -%}
 {%- if heading_font_bold != blank -%}
	<link rel="preload" as="font" href="{{ heading_font_bold | font_url }}" type="font/woff2" crossorigin>
{%- endif -%}

<style>
	@font-face {
    font-family: "IndustryInc-Base";
    src: url('https://cdn.shopify.com/s/files/1/0600/9985/4532/files/IndustryInc-Base.woff2?v=1663560931') format('woff2'),
      url("https://cdn.shopify.com/s/files/1/0600/9985/4532/files/IndustryInc-Base.woff?v=1663560931") format("woff");
    font-style: normal;
    font-display: swap;
  }
  
  @font-face {
    font-family: "IndustryInc-Cutline";
    src: url('https://cdn.shopify.com/s/files/1/0128/7208/9658/files/IndustryInc-Cutline.woff2?v=1677554958') format('woff2'),
      url("https://cdn.shopify.com/s/files/1/0128/7208/9658/files/IndustryInc-Cutline.woff?v=1677554958") format("woff");
    font-style: normal;
    font-display: swap;
  }
  
   @font-face {
    font-family: "IndustryInc-Inline";
    src: url('https://cdn.shopify.com/s/files/1/0128/7208/9658/files/IndustryInc-Inline.woff2?v=1678319114') format('woff2'),
      url("https://cdn.shopify.com/s/files/1/0128/7208/9658/files/IndustryInc-Inline.woff?v=1678319114") format("woff");
    font-style: normal;
    font-display: swap;
  }
  
  @font-face {
    font-family: "IndustryInc-InlineStroke";
    src: url('https://cdn.shopify.com/s/files/1/0141/7589/5609/files/IndustryInc-InlineStroke.woff2?v=1694993897') format('woff2'),
      url("https://cdn.shopify.com/s/files/1/0141/7589/5609/files/IndustryInc-InlineStroke.woff?v=1694993897") format("woff");
    font-style: normal;
    font-display: swap;
  }
  
  @font-face {
    font-family: "IndustryInc-InNOut";
    src: url('https://cdn.shopify.com/s/files/1/0258/6558/4714/files/IndustryInc-InNOut.woff2?v=1685693063') format('woff2'),
      url("https://cdn.shopify.com/s/files/1/0258/6558/4714/files/IndustryInc-InNOut.woff?v=1685693063") format("woff");
    font-style: 400;
    font-display: swap;
  }
  
  @font-face {
    font-family: 'Mojito-Stamp';
    src: url('https://cdn.shopify.com/s/files/1/0600/9985/4532/files/Mojito_Stamp.woff2?v=1663735184') format('woff2'),
      url('https://cdn.shopify.com/s/files/1/0600/9985/4532/files/Mojito_Stamp.woff?v=1663735197') format('woff');
    font-style: normal;
    font-display: swap;
  }
  
  @font-face {
    font-family: 'Avenir Next';
    src: url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-Regular.wof2?v=1717460673') format('wof2'),
      url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-Regular.woff?v=1717460672') format('woff');
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }
  
  @font-face {
    font-family: 'Avenir Next';
    src: url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-Medium.woff2?v=1717460672') format('woff2'),
      url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-Medium.woff?v=1717460672') format('woff');
    font-style: normal;
    font-weight: 500;
    font-display: swap;
  }
  
  @font-face {
    font-family: 'Avenir Next';
    src: url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-DemiBold.woff2?v=1717460673') format('woff2'),
      url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-DemiBold.woff?v=1717460672') format('woff');
    font-style: normal;
    font-weight: 600;
    font-display: swap;
  }
  
  @font-face {
    font-family: 'Avenir Next';
    src: url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-Bold.woff2?v=1717460672') format('woff2'),
      url('https://cdn.shopify.com/s/files/1/0162/1432/files/AvenirNext-Bold.woff?v=1717460672') format('woff');
    font-style: normal;
    font-weight: 700;
    font-display: swap;
  }

  @font-face {
    font-family: 'Julietta Messie';
    src: url('/cdn/shop/files/JuliettaMessie.woff2?v=1737525945') format('woff2'),
      url('/cdn/shop/files/JuliettaMessie.woff?v=1737525945') format('woff');
    font-style: normal;
    font-weight: normal;
    font-display: swap;
  }
	
  @font-face {
    font-family: 'Buckwheat';
    src: url('/cdn/shop/files/BuckwheatTC-Regular.woff2?v=1754442189') format('woff2'),
      url('/cdn/shop/files/BuckwheatTC-Regular.woff?v=1754442189') format('woff');
    font-style: normal;
    font-weight: normal;
    font-display: swap;
  }

	{{- settings.type_body_font | font_face: font_display: 'swap' -}}
	{{- settings.type_header_font | font_face: font_display: 'swap' -}}
	{{- body_font_bold | font_face: font_display: 'swap' -}}
	{{- body_font_italic | font_face: font_display: 'swap' -}}
	{{- body_font_bold_italic | font_face: font_display: 'swap' -}}
	{{- heading_font_bold | font_face: font_display: 'swap' -}}

	:root {
		{%- if settings.enable_body_custom_font -%}
			{% assign body_font = 'Avenir Next' %}
		{%- else -%}
			{% assign body_font = settings.type_body_font.family %}
		{%- endif -%}
		
		{%- if settings.enable_heading_custom_font -%}
			{% assign heading_font = 'IndustryInc-Base' %}
		{%- else -%}
			{% assign heading_font = settings.type_header_font.family %}
		{%- endif -%}

		--font-body-family: {{ body_font }}, {{ settings.type_body_font.fallback_families }};
		--font-body-style: {{ settings.type_body_font.style }};
		--font-body-weight: {{ settings.type_body_font.weight }};
		--font-body-size: {{ settings.body_font_base | times: '0.1' | append: 'rem' }};
		--font-heading-family: {{ heading_font }}, {{ settings.type_header_font.fallback_families }};
		--font-heading-style: {{ settings.type_header_font.style }};
		--font-heading-weight: {{ settings.type_header_font.weight }};
		--font-heading-size: {{ settings.heading_font_size }};
		--gutter: calc(var(--spacing) * 2);
		--gutter-container: calc(var(--spacing) * 2.5);
		--overlay: {{ settings.overlay_opacity | divided_by: 100.0 }};
		--type-scale: 1.125;
		--heading-1: calc(var(--heading-2) * var(--font-heading-size) * var(--type-scale));
		--heading-2: calc(var(--heading-3) * var(--font-heading-size) * var(--type-scale));
		--heading-3: calc(var(--heading-4) * var(--font-heading-size) * var(--type-scale));
		--heading-4: calc(var(--heading-5) * var(--font-heading-size) * var(--type-scale));
		--heading-5: calc(var(--font-body-size) * var(--font-heading-size) * var(--type-scale));
		--heading-6: calc(var(--font-body-size) * var(--font-heading-size) * var(--type-scale-sm, 1.067));
		--form-field-lg: 44px;
		--form-field-sm: 36px;
		--timing-function-on: cubic-bezier(.5,0,.1,1);
		--timing-function-off: cubic-bezier(.9,0,.5,1);
		--content-max-width: 100%;

		{% if settings.button_font_style == 'body' %}
			--font-button-family: var(--font-body-family);
			--font-button-style: var(--font-body-style);
			--font-button-weight: var(--font-body-weight);
		{% else %}
			--font-button-family: var(--font-heading-family);
			--font-button-style: var(--font-heading-style);
			--font-button-weight: var(--font-heading-weight);
		{% endif %}

		{% if settings.button_font_size == 'regular' %}
			--font-button-size: var(--font-body-size);
		{% else %}
			--font-button-size: calc(var(--font-body-size) * 1.2);
		{% endif %}

		{% if settings.subheading_font_style == 'body' %}
			--font-subheading-family: var(--font-body-family);
			--font-subheading-style: var(--font-body-style);
			--font-subheading-weight: var(--font-body-weight);
		{%  else %}
			--font-subheading-family: var(--font-heading-family);
			--font-subheading-style: var(--font-heading-style);
			--font-subheading-weight: var(--font-heading-weight);
		{% endif %}

		{% if settings.menu_item_font_style == 'body' %}
			--font-menu-item-family: var(--font-body-family);
			--font-menu-item-style: var(--font-body-style);
			--font-menu-item-weight: var(--font-body-weight);
		{% else %}
			--font-menu-item-family: var(--font-heading-family);
			--font-menu-item-style: var(--font-heading-style);
			--font-menu-item-weight: var(--font-heading-weight);
		{% endif %}

		{% if settings.menu_item_font_size == 'regular' %}
		--font-menu-item-size: var(--font-body-size);
		{% else %}
		--font-menu-item-size: calc(var(--font-body-size) * 1.2);
		{% endif %}

		--spacing-scale-sm: 6px;
		--spacing-scale-md: 7px;
		--spacing-scale-lg: 8px;
		--spacing: var({{settings.spacing_scale |  replace: 'small', '--spacing-scale-sm' |  replace: 'medium', '--spacing-scale-md' | replace: 'large', '--spacing-scale-lg' }});
			--color-sale-badge-text: {{ settings.color_badge_text }};
			--color-sale-badge-bg: {{ settings.color_sale_badge }};
			--color-sold-out-badge-text: {{ settings.color_sold_out_badge_text }};
			--color-sold-out-badge-background: {{ settings.color_sold_out_badge_background }};
		--color-new-badge-background: {{ settings.color_new_in_badge_background }};
		--color-new-badge-text: {{ settings.color_new_in_badge_text }};
		--color-custom-badge-background: {{ settings.custom_badge_background_color }};
		--color-custom-badge-text: {{ settings.custom_badge_text_color }};
			--color-success: #10873f;
			--color-danger: #da3d08;
			--color-warning: #e38c09;
	}

	{% for scheme in settings.color_schemes -%}
		{% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
		{% if forloop.index == 1 -%}
			:root,
			{%- endif %}
			.color-{{ scheme.id }} {
			--color-page-bg: {{ scheme.settings.color_background }};
			--color-page-bg-rgb: {{ scheme.settings.color_background.red }}, {{ scheme.settings.color_background.green }}, {{ scheme.settings.color_background.blue }};
			--color-normal-text: {{ scheme.settings.color_body_text }};

			--gradient-background: {{ scheme.settings.color_background }};
			{% if scheme.settings.background_gradient != blank %}
				--gradient-background: {{ scheme.settings.background_gradient }};
			{% endif %}

			--color-normal-text-rgb: {{ scheme.settings.color_body_text.red }}, {{ scheme.settings.color_body_text.green }}, {{ scheme.settings.color_body_text.blue }};
			--color-btn-bg-rgb: {{ scheme.settings.primary_button_background.red }}, {{ scheme.settings.primary_button_background.green }}, {{ scheme.settings.primary_button_background.blue }};

			--primary_button_background_gradient: {{ scheme.settings.primary_button_background }};
			{% if scheme.settings.primary_button_background_gradient != blank %}
				--primary_button_background_gradient: {{ scheme.settings.primary_button_background_gradient }};
			{% endif %}

			--color-btn-label: {{ scheme.settings.primary_button_color_text }};
			--color-btn-secondary-bg-rgb: {{ scheme.settings.secondary_button_background.red }}, {{ scheme.settings.secondary_button_background.green }}, {{ scheme.settings.secondary_button_background.blue }};

			--secondary_button_background_gradient: {{ scheme.settings.secondary_button_background }};
			{% if scheme.settings.secondary_button_background_gradient != blank %}
				--secondary_button_background_gradient: {{ scheme.settings.secondary_button_background_gradient }};
			{% endif %}

			--color-light-text: rgba(var(--color-normal-text-rgb), .6);
			--color-disabled-text: rgba(var(--color-normal-text-rgb), .3);
			--color-btn-secondary-label: {{ scheme.settings.secondary_button_color_text }};

			--color-badge-text: {{ scheme.settings.badge_text }};
			--color-badge-background: {{ scheme.settings.badge_background }};

			--color-main-accent-text: {{ scheme.settings.color_accent_text_one }};
			--color-main-accent-bg: {{ scheme.settings.color_accent_background_one }};

			--color-extra-accent-text: {{ scheme.settings.color_accent_text_two }};
			--color-extra-accent-bg: {{ scheme.settings.color_accent_background_two }};

			--color-bg-line: rgba(var(--color-normal-text-rgb), .04);
			--color-divider: rgba(var(--color-normal-text-rgb), .12);
			--color-border: var(--color-divider);
		}
	{% endfor %}
	{{ scheme_classes | prepend: 'body' }} {
		color: rgb(var(--color-normal-text-rgb));
		background: var(--gradient-background);
	}
	.background {
		background: var(--gradient-background);
	}
	@media (min-width: 459px) {
		:root {
			--type-scale: 1.2;
			--type-scale-sm: 1.125;
		}
	}
	@media (min-width: 769px) {
		:root {
			--form-field-lg: 50px;
			--form-field-sm: 44px;
			--spacing-scale-sm: 9px;
			--spacing-scale-md: 10.5px;
			--spacing-scale-lg: 12px;
		}
	}
	@media (min-width: 1025px) {
		:root {
			--spacing-scale-sm: 12px;
			--spacing-scale-md: 14px;
			--spacing-scale-lg: 16px;
			--gutter-container: calc(var(--spacing) * 4);
		}
	}
	@media (min-width: 1681px) {
		:root {
			--type-scale: 1.25;
			--type-scale-sm: 1.2;
			--spacing-scale-sm: 15px;
			--spacing-scale-md: 17.5px;
			--spacing-scale-lg: 20px;
		}
	}
	{%- if settings.enable_content_max_width -%}
		:root {
			--content-max-width: {{ settings.content_max_width }}px;
		}

		@media (min-width: 1681px) {
			:root {
				--spacing-scale-sm: 12px;
				--spacing-scale-md: 14px;
				--spacing-scale-lg: 16px;
			}
		}
	{%- endif -%}
</style>
