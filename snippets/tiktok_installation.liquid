<script type="lazyload2">
  var checkout_btn = document.querySelectorAll(".quickview-form__buttons .js-product-form-submit-btn");
  
  checkout_btn.forEach((checkout) => {
    checkout.addEventListener('click', (e) => {
      fetch(window.Shopify.routes.root + 'cart.js', {
        method: 'GET'
      })
      .then(response => {
        return response.json();
      })
      .then(cart => { 
        console.log(cart);
        const cartItems = cart.items.map(item => ({
          content_id: item.variant_id,
          content_type: 'product',
          content_name: item.title,
          quantity: item.quantity,
          price: item.price / 100
        }));
  
        ttq.track(('InitiateCheckout'), {
          contents: cartItems,
          value: cart.total_price / 100,
          currency: cart.currency,
          });
      })
      .catch((error) => {
        console.error('Error:', error);
      });
    });
  });
</script>

{% if request.page_type contains 'product' %}
  <script type="lazyload2">
      ttq.track('ViewContent',{
        content_id: {{ product.id }},
        content_name: '{{ product.title }}',
        quantity: 1,
        price: {{ product.price | money_without_currency }},
        value: {{ product.price | money_without_currency }},
        currency: '{{ cart.currency.iso_code }}'
      });
  </script>

  <script type="lazyload2">
    var productAddToCart = document.querySelector("form[action] button.product-btn-atc");
    var stickyAddToCart = document.querySelector("sht-prd-frm-sticky button.product-btn-atc");

    const track = () => {
      ttq.track('AddToCart', {
        content_id: {{ product.id }},
        content_name: '{{ product.title }}',
        quantity: 1,
        price: {{ product.price | money_without_currency }},
        value: {{ product.price | money_without_currency }},
        currency: '{{ cart.currency.iso_code }}'
      });
    }
    
    productAddToCart.addEventListener('click', (e) => {
      track();
    });

    stickyAddToCart.addEventListener('click', (e) => {
      track();
    });
  </script>
{% endif %}