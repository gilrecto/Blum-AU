{%- liquid
  assign media = 'image' | placeholder_svg_tag: 'placeholder w-100 h-100 of-cover js-image-lazy'
-%}
<sht-cart-drwr id="shtCartDrawer" class="drawer cart__drawer js-cart-drawer no-focus-visible" aria-hidden="true" hidden tabindex="-1">
  <div class="cart-drawer" id="cartDrawer">
    <div class="drawer__overlay js-cart-drawer-overlay js-drawer-overlay"></div>
    <div class="drawer__wrapper cart-drawer__wrapper js-cart-drawer-wrapper js-drawer-wrapper p-absolute" role="dialog" aria-label="{{ 'sections.cart.title' | t }}" aria-modal="true">
      {%- if cart == empty -%}
        <div class="drawer__header d-flex between-xs visually-hidden">
          <h2 class="drawer__heading h5 ts:!ml-auto">{{ 'general.cart.label' | t }}</h2>
          <button class="js-cart-drawer-btn-close js-drawer-btn-close btn btn-plain btn-icon ts:!ml-auto" onclick="window.shtCartDrawer.closeDrawer();" type="button" aria-label="{{ 'accessibility.close' | t }}">
            {% render 'icon-close' %}
          </button>
        </div>
        <div class="drawer__body oy-auto d-flex center-xs middle-xs fd-column flex-1">
          <span class="h5 mb-32">{{ 'general.cart.cart_empty' | t }}</span>
          <sht-cart-drwr-frm>
            {%- assign url = routes.all_products_collection_url -%}
            {%- if settings.no_view_url != blank -%}
              {%- assign url = settings.no_view_url -%}
            {%- endif -%}
            <a href="{{ url }}" class="btn btn-primary btn-large">
              {{ 'general.cart.continue_shopping' | t }}
            </a>
          </sht-cart-drwr-frm>
        </div>
      {%- else -%}
        <div class="drawer__header d-flex middle-xs between-xs">
          <h2 class="drawer__heading h5 m-zero ts:!ml-auto">{{ 'general.cart.cart_draw_title' | t: item_count: cart.item_count }}</h2>
          <button class="js-cart-drawer-btn-close js-drawer-btn-close btn btn-small btn-icon btn-plain ts:!ml-auto" onclick="window.shtCartDrawer.closeDrawer();" type="button" aria-label="{{ 'accessibility.close' | t }}">
            {% render 'icon-close' %}
          </button>
        </div>
        <div class="drawer__body oy-scroll oy-auto flex-1 ts:flex ts:flex-col">
          {% if settings.cart_show_free_shipping_notification and settings.cart_minimum_order_price_for_free_shipping != blank %}
            <div class="js-free-shipping-notification-message free-shipping-notification cart-drawer-shipping pt-8 pb-8 ts:!border-b-0">
              {% render 'free-shipping-amount', cart: cart, section: section %}
            </div>
          {% endif %}

          {%- render 'free_mini_selector' -%}

          <sht-cart-drwr-frm class="ts:flex-1">
            <form action="{{ routes.cart_url }}" id="cart-drawer-form" class="cart-drawer__form" method="post">
              <ul class="js-cart-items ls-none">
                {%- for item in cart.items -%}
                  <li id="cartDrawerItem-{{ item.index | plus: 1 }}" class="cart-drawer__product gap-16 d-grid{% if item.original_price <= 0 %} free-item{% endif %}">
                    {%- liquid
                      assign media = 'image' | placeholder_svg_tag: 'placeholder js-image-lazy'
                      assign media = item.image | image_url: width: 300 | image_tag: widths: '300', sizes: '100vw', alt: item.product.title, class: 'js-image-lazy media of-cover'
                    %}
                    <div class="cart-drawer__product__media p-relative">
                      {%- if item.original_price <= 0 -%}
                        <span class="qty-badge">
                          {{ item.quantity }}
                        </span>
                      {%- endif -%}
                      {% render 'image', image_item: media, src: block.settings.image.src %}
                    </div>
                    <div class="cart-drawer__product-info">
                      <div class="cart-drawer__product-info--top d-grid pb-4">
                        <div class="cart-drawer__product-info--title">
                          {%- if settings.enable_cart_product_vendor -%}
                            <p class="subtext color-light mb-4 hide-empty">
                              {{ item.product.vendor }}
                            </p>
                          {%- endif -%}

                          <a href="{{ item.url }}" class="product-title wb-break-word h6 d-block mb-0 ts:max-sm:!text-base">{{ item.product.title | escape }}</a>
                          
                          {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != null -%}
                            <div class="cart-drawer__item__options">
                              <dl class="subtext color-light m-zero">
                                {%- if item.product.has_only_default_variant == false -%}
                                  <div class="cart-drawer__item__option">
                                    <span>
                                      {%- liquid
                                        assign options_names = ''
                                        for option in item.options_with_values
                                          assign options_names = options_names | append: ', ' | append: option.value
                                        endfor
                                        echo  options_names | replace_first: ', ', ''
                                      -%}
                                      </span>
                                  </div>
                                {%- endif -%}
                                {%- for property in item.properties -%}
                                  {%- assign property_first_char = property.first | slice: 0 -%}
                                  {%- if property.last != blank and property_first_char != '_' -%}
                                    <div class="cart-drawer__item__option">
                                      <p class="d-block mt-4">
                                        {{ property.first }}:
                                        {% if property.last contains '/uploads/' %}
                                          <a href="{{ property.last }}" class="link" target="_blank" aria-describedby="a11y-new-window-message">
                                            {{ property.last | split: '/' | last }}
                                          </a>
                                        {% else %}
                                          {{ property.last }}
                                        {% endif %}
                                      </p>
                                    </div>
                                  {%- endif -%}
                                {%- endfor -%}
                              </dl>
                            </div>
                          {%- endif -%}
                          {%- if item.variant.available and item.unit_price_measurement -%}
                            <div class="cart-drawer__item__unit-price subtext color-light mt-8">
                              <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                              {{ item.variant.unit_price | money }}
                              <span aria-hidden="true">/</span>
                              <span class="visually-hidden">&nbsp;per&nbsp;</span>
                              {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                                {{- item.variant.unit_price_measurement.reference_value -}}
                              {%- endif -%}
                              {{ item.variant.unit_price_measurement.reference_unit }}
                            </div>
                          {%- endif -%}
                        </div>
                        <div class="cart-drawer__product-price color-accent-bg-1">
                          <div class="ta-left">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <div class="cart-item__discounted-prices wb-break-word">
                                <span class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </span>
                                <span class="d-block fw-700 color-accent-bg-1">
                                  {{ item.final_line_price | money }}
                                </span>
                                <span class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </span>
                                <s class="color-light subtext">
                                  {{ item.original_line_price | money }}
                                </s>
                              </div>
                            {%- else -%}
                              <span class="d-block fw-700 color-accent-bg-1">
                                {{ item.original_line_price | money }}
                              </span>
                              {% if item.variant.compare_at_price > item.variant.price %}
                                <s class="color-light subtext d-block ts:!text-red ts:font-medium"> {{ item.variant.compare_at_price | times:  item.quantity | money }}</s>
                              {% endif %}
                            {%- endif -%}
                          </div>
                        </div>
                      </div>
                      <div class="cart-drawer__product-price color-accent-bg-1 d-none" hidden>
                        {%- if item.original_price != item.final_price -%}
                          <span class="visually-hidden">
                            {{ 'products.product.price.regular_price' | t }}
                          </span>
                          <s>{{- item.original_price | money -}}</s>
                          <span class="visually-hidden">
                            {{ 'products.product.price.sale_price' | t }}
                          </span>
                          <strong>{{ item.final_price | money }}</strong>
                        {%- else -%}
                          {{ item.original_price | money }}
                        {%- endif -%}
                      </div>
                      {% if item.selling_plan_allocation != nil %}
                        <div class="cart-drawer__item__option hide-empty d-flex middle-xs pb-8">
                          <span class="icon icon--small color-accent-2 mr-8 fs-0">
                            {% render 'icon-subscription', size: 16 %}
                          </span>
                          <span>
                            {{ item.selling_plan_allocation.selling_plan.name }}
                          </span>
                        </div>
                      {% endif %}
                      <!-- Variants and Selling Plan -->
                      <!-- Discounts -->
                      <ul class="ls-none hide-empty p-zero">
                        {%- for discount in item.discounts -%}
                          <li class="cart-item__discounted d-grid middle-xs pb-8 ts:!text-xs ts:font-medium" aria-label="{{ discount.title }}">
                            <span class="icon icon--small color-accent-2 mr-8 fs-0">
                              {% render 'icon-voucher', size: 16 %}
                            </span>
                            <span>{{- discount.savings | money -}}</span>
                          </li>
                        {%- endfor -%}
                      </ul>
                      
                      {%- unless item.original_price <= 0 %}
                        <div class="d-flex middle-xs pt-12">
                          <label class="visually-hidden" for="cartDrawerQuantityField-{{ item.index | plus: 1 }}">{{ 'products.product.quantity.label' | t }}</label>
                          <sht-cart-drwr-qty-inp class="field_quantity d-inline-flex middle-xs center-xs btn-small mr-12">
                            <button class="js-cart-drawer-quantity-btn js-cart-drawer-quantity-btn-minus js-cart-drawer-btn btn btn-plain btn-small btn-icon" name="minus" data-name="minus" type="button">
                              <span class="visually-hidden">{{ 'general.cart.decrease' | t }}</span>
                              {% render 'icon-minus', size: 20 %}
                            </button>
                            <input class="js-cart-drawer-quantity-input input-number qty-element--sm btn-plain b-zero ta-center" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}" id="cartDrawerQuantityField-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                            <button class="js-cart-drawer-quantity-btn js-cart-drawer-quantity-btn-plus js-cart-drawer-btn btn btn-plain btn-small btn-icon" name="plus" data-name="plus" type="button">
                              <span class="visually-hidden">{{ 'general.cart.increase' | t }}</span>
                              {% render 'icon-plus', size: 20 %}
                            </button>
                          </sht-cart-drwr-qty-inp>
                          <sht-cart-drwr-rmv-btn id="cartDrawerRemove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                            <button class="js-cart-drawer-delete-btn js-cart-drawer-btn btn btn-secondary btn-plain btn-small" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}" type="button">
                              <span class="ts:uppercase ts:text-xs ts:underline">{{ 'sections.cart.remove_title' | t: title: '' }}</span>
                              {% render 'icon-remove', class: 'visually-hidden' %}
                            </button>
                          </sht-cart-drwr-rmv-btn>
                        </div>
                      {% endunless -%}
                      <div class="d-none-important d-flex mt-16 center-cs middle-xs" id="cart-drawer-line-item-error-{{ item.index | plus: 1 }}" role="alert">
                        <div class="icon icon--small icon--error fs-0 mr-8">
                          {% render 'icon-error', size: 16 %}
                        </div>
                        <small class="js-cart-drawer-form-item-error-message"></small>
                      </div>
                    </div>
                  </li>
                {%- endfor -%}
              </ul>
              <div id="cart-drawer__errors" class="js-cart-drawer-errors" role="alert"></div>
            </form>

          </sht-cart-drwr-frm>

          {% if settings.show_discount_field and cart != empty %}
            <div class="cart__discount rad-m border">
              {% render 'cart-discount', section: section %}
            </div>
          {% endif %}

          {% if settings.enable_cart_order_notes %}
            {%- liquid
              assign note_bg = false

              if settings.cart_note_bg != blank
                assign note_bg = true
              endif
            -%}
            <details class="">
              <summary class="cart-order-notes ls-none w-100 ts:!max-w-full ts:flex ts:items-center ts:justify-between">
                <span class="btn btn-link ts:!py-0 ts:uppercase ts:!no-underline  ts:!text-xs">
                  {{ 'general.cart.cart_note_title' | t }}
                </span>
                <span class="cart-note-header ts:uppercase ts:font-semibold ts:!text-xs">{{ 'general.cart.cart_note_header' | t }}</span>
                <div class="btn-close-note btn btn-icon ts:!py-0 ts:ml-auto" aria-label="{{ 'accessibility.close' | t }}" title="{{ 'accessibility.close' | t }} Cart Note">
                  {% render 'icon-close', class: 'ts:w-8 ts:h-8' %}
                </div>
              </summary>
              <sht-cart-drwr-note class="field mt-8 d-block{% if note_bg %} ts:bg-[rgba(0,0,0,0.7)] ts:bg-[image:var(--note-bg)] ts:bg-blend-overlay ts:p-8{% endif %}"{% if note_bg %} style="--note-bg: url({{ settings.cart_note_bg | image_url: width: 420 }})"{% endif %}>
                <label class="visually-hidden" for="cartDrawerNoteInput">{{ 'general.cart.cart_note_title' | t }}</label>
                <textarea id="cartDrawerNoteInput" class="field__text field--focus field--hover w-100 textarea" name="note" placeholder="{{ 'general.cart.cart_note_placeholder' | t }}" rows="5">{{ cart.note }}</textarea>
              </sht-cart-drwr-note>
            </details>
          {% endif %}
        </div>

       {% render 'side_cart_upsell' %}

        <div class="drawer__footer p-sticky bottom-0 cart-drawer__footer">
          <div class="js-cart-level-discount-applications hide-empty mb-24">
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul class="ls-none" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="cart-item__discounted d-flex middle-xs between-xs">
                    <div class="d-flex middle-xs">
                      <span class="icon icon--small color-accent-2 mr-8 fs-0">
                        {% render 'icon-voucher', size: 16 %}
                      </span>
                      <span>{{ discount.title }}</span>
                    </div>
                    <span class="flex-1 ta-right">-{{ discount.total_allocated_amount | money }}</span>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
          <div class="js-cart-total d-flex middle-xs between-xs mb-24">
            <h2 class="h5 m-zero ts:!font-body ts:uppercase ts:!font-bold">{{ 'general.cart.total' | t }}</h2>
            <p class="m-zero h5 color-accent-bg-1 ts:!font-body ts:!font-semibold">{{ cart.total_price | money }}</p>
          </div>
          <div class="mb-8 d-flex gap-12">
            <noscript>
              <button type="submit" class="btn btn-large btn-primary w-100" form="cart-drawer-form">
                {{ 'sections.cart.update' | t }}
              </button>
            </noscript>
            {%- if settings.show_view_cart_button or customer.b2b? -%}
              <a href="{{- routes.cart_url -}}" class="btn btn-large btn-secondary w-100">{{ 'sections.cart.view_cart' | t }}</a>
            {%- endif -%}
            
            {%- unless customer.b2b? -%}
              <button type="submit" class="js-cart-drawer-submit-btn cart-drawer--checkout-btn btn btn-large btn-primary w-100" name="checkout" form="cart-drawer-form" {% if cart == empty %} disabled{% endif %}>
                {{ 'sections.cart.checkout' | t }}
              </button>
            {%- endunless -%}
          </div>
          {% if settings.show_cart_tax_info %}
            <small class="tax-note subtext d-block ta-center color-light text-block ts:uppercase ts:!text-[1.1rem] ts:font-medium mb-12">
              {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
              {%- elsif cart.taxes_included -%}
                {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
              {%- elsif shop.shipping_policy.body != blank -%}
                {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
              {%- else -%}
                {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
              {%- endif -%}
            </small>
          {% endif %}

          {%- if settings.show_payment_options -%}
            <div class="payment-options">
              <ul class="list list-payment d-flex gap-8 center-xs fw-wrap ls-none">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="list-payment__item d-flex">
                    {{ type | payment_type_svg_tag: class: 'icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</sht-cart-drwr>