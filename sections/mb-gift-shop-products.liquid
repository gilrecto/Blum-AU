{%- liquid
  assign section_id = section.id | md5 | truncate: 12, ""
  assign blocks_length = section.blocks | size
-%}

<div class="section gift-shop-products p-relative color-{{ section.settings.color_scheme }} {{ section.settings.remove_padding_top | replace: 'true', 'section-top-zero' | replace: section.settings.remove_padding_top, '' }} {{ section.settings.remove_padding_bottom | replace: 'true', 'section-bottom-zero' | replace: section.settings.remove_padding_bottom, '' }} {% render 'animation-loader', section: section %}" data-ui-component="Gift Shop Products Section" role="region" aria-labelledby="sectionHeading-{{ section_id }}">
  {%- if section.settings.title != blank or section.settings.text != blank -%}
    <div class="ctnr">
      <div class="s-header ta-center">
        <div class="rw center-xs">
          <div class="clm js-animate anm anm-fadeInUp" style="--w-xs:12;--w-sm:10; --duration: .6s; --delay: .3s;">
            {%- if section.settings.title != blank -%}
              <h2 class="s-header__title" id="sectionHeading-{{ section_id }}">{{ section.settings.title }}</h2>
            {%- endif -%}
            {%- if section.settings.text != blank -%}
              <div class="s-header__desc rte">
                {{ section.settings.text }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
    
  {% if blocks_length > 0 %}
    <div class="s-content">
      {%- comment -%} Special Products Section {%- endcomment -%}
      {%- assign special_products = section.blocks | where: "type", "special_prod" -%}
      {%- if special_products.size > 0 -%}
        <div class="rw gap-unequal center-xs mb-48 mb-md-64 js-animate">
          {%- for block in special_products -%}
            {%- liquid
              assign product = block.settings.product
              assign col_width = 12.0 | divided_by: special_products.size | at_most: 3
            -%}
            {%- if product != blank -%}
              <div class="clm anm anm-fadeInUp fd-column" style="--w-xs:12;--w-md:{{ col_width }}; --delay: {{ forloop.index | times: 0.05 -}}s; --duration: .6s;" {{ block.shopify_attributes }}>
                <div class="{{ block.settings.container }}">
                  {% render 'mb_gift_shop_product_card',
                    product: product,
                    show_vendor: false,
                    show_color_swatch: false,
                    show_sale_badge: true,
                    enable_quick_buy: settings.enable_quick_buy,
                    ratio: settings.product_card_image_ratio,
                    show_second_image: settings.show_second_image,
                    section: section,
                    is_first: forloop.first
                  %}
                  {%- if block.settings.label != blank -%}
                    <div class="ta-center mt-12" style="color: {{ block.settings.color }};">
                      <span class="fw-700">{{ block.settings.label }}</span>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
      
      {%- comment -%} Multiple Products Sections {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'multi_prod' -%}
          {%- liquid
            assign product_list = block.settings.product_list
            assign limit = block.settings.limit | default: 3
            assign col_width = 12.0 | divided_by: limit
          -%}
          <div class="multi-products-block {{ block.settings.title | handleize | escape }} ts:relative" {{ block.shopify_attributes }}>
            <div class="{{ block.settings.container }}">
              {%- if block.settings.title != blank -%}
                <div class="title-area ta-center ts:relative ts:z-1">
                  <h3 class="h3 block-title js-animate anm anm-fadeInUp" style="--duration: .6s; --delay: .3s">{{ block.settings.title }}</h3>
                </div>
              {%- endif -%}
              <div class="rw gap-unequal center-xs js-animate">
                {%- for product in product_list limit: limit -%}
                  {%- unless product.price == 0 or product.tags contains settings.no_view_tag -%}
                    <div class="clm anm anm-fadeInUp fd-column" style="--w-xs:4;--w-md:{{ col_width }}; --delay: {{ forloop.index | times: 0.05 -}}s; --duration: .6s;">
                      {% render 'mb_gift_shop_product_card',
                        product: product,
                        show_vendor: false,
                        show_color_swatch: settings.show_color_swatches,
                        show_sale_badge: true,
                        enable_quick_buy: settings.enable_quick_buy,
                        ratio: settings.product_card_image_ratio,
                        show_second_image: settings.show_second_image,
                        section: section,
                        is_first: forloop.first
                      %}
                      {%- if block.settings.label != blank -%}
                        <div class="ta-center mt-12" style="color: {{ block.settings.color }};">
                          <span class="fw-700">{{ block.settings.label }}</span>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endunless -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Gift Shop Products",
  "tag": "section",
  "class": "mb-gift-shop-prods",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Section Subtext"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "label": "t:general.settings.remove_padding_top.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_padding_bottom",
      "label": "t:general.settings.remove_padding_bottom.label",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "special_prod",
      "name": "Special Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Special Product"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom Label",
          "default": "Special"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Custom Button Label",
          "info": "Leave blank to use theme default"
        },
        {
          "type": "header",
          "content": "Block Settings"
        },
        {
          "type": "select",
          "id": "container",
          "label": "Container Type",
          "options": [
            {
              "value": "ctnr",
              "label": "Box"
            },
            {
              "value": "ctnr-banner",
              "label": "Fullwidth"
            }
          ],
          "default": "ctnr"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Label Color",
          "default": "#000000"
        }
      ]
    },
    {
      "type": "multi_prod",
      "name": "Multiple Products",
      "settings": [
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Choose Products",
          "limit": 6,
          "info": "Maximum of 6 products"
        },
        {
          "type": "range",
          "id": "limit",
          "min": 1,
          "max": 6,
          "step": 1,
          "label": "Products to Show",
          "default": 3
        },
        {
          "type": "text",
          "id": "title",
          "label": "Block Title",
          "default": "Our Specials"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom Label",
          "default": "Gifting"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Custom Button Label",
          "info": "Leave blank to use theme default"
        },
        {
          "type": "header",
          "content": "Block Settings"
        },
        {
          "type": "select",
          "id": "container",
          "label": "Container Type",
          "options": [
            {
              "value": "ctnr",
              "label": "Box"
            },
            {
              "value": "ctnr-banner",
              "label": "Fullwidth"
            }
          ],
          "default": "ctnr"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Label Color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gift Shop Products",
      "category": "Products"
    }
  ]
}
{% endschema %}

