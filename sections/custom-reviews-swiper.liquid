67 168.29 140.33 169.04 156.98 169.86 C 162.60 170.04 168.07 171.49 173.67 171.94 C 177.74 160.76 184.00 150.60 188.81 139.75 C 192.71 131.12 196.39 122.38 199.64 113.48 C 206.96 93.34 215.19 73.54 224.07 54.04 C 227.42 46.58 231.19 39.32 235.20 32.19 Z" />
