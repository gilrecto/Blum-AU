{%- liquid
  assign section_id = section.id | md5 | truncate: 12, ""
  assign loading = "lazy"
  assign decoding ="async"
  assign fetchpriority = "auto"
  if section.index == 1
    assign loading = "eager"
    assign fetchpriority = "high"
    assign image_classes = 'w-100 h-100'
  endif
-%}

