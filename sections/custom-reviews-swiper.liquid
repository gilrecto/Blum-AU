<div class="custom-reviews-swiper section color-{{ section.settings.color_scheme }} {{ section.settings.remove_padding_top | replace: 'true', 'section-top-zero' | replace: section.settings.remove_padding_top, '' }} {{ section.settings.remove_padding_bottom | replace: 'true', 'section-bottom-zero' | replace: section.settings.remove_padding_bottom, '' }} {% render 'animation-loader', section: section %}" data-ui-component="Custom Reviews Swiper Section" role="region" aria-labelledby="sectionHeading-{{ section_id }}">
  <div class="ctnr">
    <!-- Skeleton Loader -->
    <div class="reviews-skeleton ts:grid ts:lg:grid-cols-2 ts:grid-cols-1 ts:lg:gap-x-[3vw] ts:max-lg:gap-y-10 ts:max-lg:flex-wrap" id="skeleton-{{ section_id }}">
      <!-- Text Content Skeleton (Left Side) -->
      <div class="text-skeleton-column ts:lg:flex-[1_1_50%] ts:flex-[0_0_100%]">
        <div class="ts:animate-pulse">
          <!-- Header skeleton -->
          <div class="ts:mb-8">
            <div class="ts:h-8 ts:bg-gray-200 ts:rounded ts:w-3/4 ts:mb-4"></div>
            <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-full ts:mb-2"></div>
            <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-5/6"></div>
          </div>
          
          <!-- Review content skeleton -->
          <div class="ts:space-y-6">
            <!-- Star rating skeleton -->
            <div class="ts:flex ts:gap-1">
              {% for star in (1..5) %}
                <div class="ts:w-5 ts:h-5 ts:bg-gray-200 ts:rounded-sm"></div>
              {% endfor %}
            </div>
            
            <!-- Review text skeleton -->
            <div class="ts:space-y-3">
              <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-full"></div>
              <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-11/12"></div>
              <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-10/12"></div>
              <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-9/12"></div>
              <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-8/12"></div>
            </div>
            
            <!-- Author skeleton -->
            <div class="ts:h-4 ts:bg-gray-200 ts:rounded ts:w-1/3"></div>
          </div>
          
          <!-- Navigation dots skeleton (desktop only) -->
          <div class="ts:hidden ts:lg:flex ts:justify-center ts:gap-2 ts:mt-8">
            {% for dot in (1..5) %}
              <div class="ts:w-2 ts:h-2 ts:bg-gray-200 ts:rounded-full"></div>
            {% endfor %}
          </div>
        </div>
      </div>
      
      <!-- Image Content Skeleton (Right Side) -->
      <div class="image-skeleton-column ts:lg:flex-[1_1_50%] ts:flex-[0_0_100%]">
        <div class="ts:animate-pulse">
          <!-- Large image skeleton -->
          <div class="ts:w-full ts:aspect-[4/3] ts:bg-gray-200 ts:rounded-lg ts:mb-4"></div>
          
          <!-- Navigation dots skeleton (mobile only) -->
          <div class="ts:flex ts:lg:hidden ts:justify-center ts:gap-2">
            {% for dot in (1..5) %}
              <div class="ts:w-2 ts:h-2 ts:bg-gray-200 ts:rounded-full"></div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    <div class="s-content ts:grid ts:lg:grid-cols-2 ts:grid-cols-1 ts:lg:gap-x-[3vw] ts:max-lg:gap-y-10">
      <div class="text--slider-colmn">
        <swiper-slider class="text-content__reviews-{{ section_id }} ts:opacity-0 ts:transition-opacity ts:duration-500 ts:h-full ts:lg:pt-20 ts:lg:pr-16 ts:!pb-0" data-section-id="{{ section_id }}" data-skeleton-id="skeleton-{{ section_id }}">
          {% render 'section-header',
            subheading: section.settings.subheading,
            heading: section.settings.heading,
            description: section.settings.description,
            content_align: section.settings.content_align,
            section: section
          %}

          <div class="swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'review' %}
                  <div class="swiper-slide">
                    <div class="review-card {{ section.settings.content_align }}" {{ block.shopify_attributes }}>
                      <div class="review-txt-wrapper ts:space-y-7 ts:bg-[rgba(var(--color-page-bg-rgb))]">
                        <!-- Star Rating -->
                        <div class="review-stars-wrapper ts:flex ts:gap-2">
                          {%- for i in (1..5) -%}
                            {% if i <= block.settings.rating %}
                              {{ star | replace: 'color_class', 'ts:text-putty' }}
                            {% else %}
                              {{ star | replace: 'color_class', 'ts:text-gray-300' }}
                            {% endif %}
                          {%- endfor -%}
                        </div>
                        
                        <div class="rte ts:w-full ts:max-w-[68rem] ts:text-[clamp(1.5rem,2.5vw,2.4rem)] ts:leading-[1.6]">
                          {%- if block.settings.review_text != blank -%}
                            {{ block.settings.review_text }}
                          {%- endif -%}

                          <!-- Author -->
                          <div class="review-author ts:mt-6">
                            - {{ block.settings.author_name }}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            
            <div class="controls hide-empty ts:lg:block ts:hidden ts:lg:mt-[5vw]">
              <!-- Navigation -->
              {%- if section.settings.show_navigation -%}
                <div class="swiper-nav--wrapper ts:flex ts:items-center ts:justify-center ts:gap-10 ts:mb-12">
                  <div class="swiper-button-prev ts:!relative ts:!text-[rgba(var(--color-normal-text))] ts:!w-[2.5rem] ts:!h-[2.5rem] ts:after:!text-[2.5rem] ts:!top-0 ts:!left-0 ts:!right-0 ts:!mt-0"></div>
                  <div class="swiper-button-next ts:!relative ts:!text-[rgba(var(--color-normal-text))] ts:!w-[2.5rem] ts:!h-[2.5rem] ts:after:!text-[2.5rem] ts:!top-0 ts:!left-0 ts:!right-0 ts:!mt-0"></div>
                </div>
              {%- endif -%}

              <!-- Pagination -->
              {%- if section.settings.show_pagination -%}
                <div class="swiper-pagination ts:!relative ts:!bottom-0"></div>
              {%- endif -%}
            </div>
          </div>
        </swiper-slider>
      </div>

      <div class="img-slider-colmn">
        <swiper-slider class="image-content__reviews-{{ section_id }} ts:h-full ts:!py-0 ts:opacity-0 ts:transition-opacity ts:duration-500" data-section-id="{{ section_id }}" data-skeleton-id="skeleton-{{ section_id }}">
          <div class="swiper ts:lg:h-full">
            <div class="swiper-wrapper">

              {% for block in section.blocks %}
                {% if block.type == 'review' %}
                  <div class="swiper-slide">
                    <div class="review-card ts:h-full" {{ block.shopify_attributes }}>
                      {% if block.settings.review_image != blank %}
                        <div class="review-img-wrapper ts:w-full ts:h-full">
                          {%- liquid
                            assign image_raw = block.settings.review_image
                            assign image_alt = image_raw.alt | default: image_raw.image | split: '/' | last
                            assign img_class = 'js-image-lazy media of-cover w-100 h-100 js-animate anm anm-fadeInUp'
                            assign delay = forloop.index | times: 0.3
                            assign media_wrap_style = '--duration: .6s; --delay: ' | append: delay | append: 's;'

                            assign image = image_raw | image_url: width: image_raw.width | image_tag: widths: '320, 450, 550, 750, 950, 1024, 1200', sizes: '(min-width: 459px) calc(100vw/2), 100vw', alt: image_alt, class: img_class, loading: loading, fetchpriority: fetchpriority, decoding: decoding
                          -%}

                          {%- render 'image', image_item: image, image_wrap_classes: 'h-100 ts:*:h-full', media_wrap_style: media_wrap_style -%}
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            
            <div class="controls hide-empty ts:lg:hidden ts:block ts:relative ts:mt-12">
              <!-- Pagination -->
              {%- if section.settings.show_pagination -%}
                <div class="swiper-pagination ts:!relative ts:!bottom-0"></div>
              {%- endif -%}
              
              <!-- Navigation -->
              {%- if section.settings.show_navigation -%}
                <div class="swiper-button-prev ts:!text-[rgba(var(--color-normal-text))] ts:!w-[2.5rem] ts:!h-[2.5rem] ts:after:!text-[2.5rem] ts:!mt-0 ts:!top-0"></div>
                <div class="swiper-button-next ts:!text-[rgba(var(--color-normal-text))] ts:!w-[2.5rem] ts:!h-[2.5rem] ts:after:!text-[2.5rem] ts:!mt-0 ts:!top-0"></div>
              {%- endif -%}
            </div>
          </div>
        </swiper-slider>
      </div>
    </div>

    {%- if section.settings.show_view_all_button -%}
      {%- assign default_text_btn = "general.search.view_all" | t -%}
      <div class="s-footer {{ section.settings.content_align }} {{ section.settings.show_view_all_button | default: 'd-none' | replace: 'true', '' }}">
        <a href="{{- section.settings.button_link | default: "#" -}}" class="btn {{ section.settings.btn_type }} btn-large ts:max-sm:w-full">
          {{- section.settings.button_text | default: default_text_btn -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const textSlider = document.querySelector('.text-content__reviews-{{ section_id }}');
    const imageSlider = document.querySelector('.image-content__reviews-{{ section_id }}');
    
    if (textSlider && imageSlider) {
      // Flags to prevent infinite loop
      let isTextSliderChanging = false;
      let isImageSliderChanging = false;
      
      // Configuration for text slider (master)
      const textConfig = {
        slidesPerView: 1,
        spaceBetween: 20,
        freeMode: false,
        loop: {{ section.settings.enable_loop }},
        {% if section.settings.enable_autoplay %}
          autoplay: {
            delay: {{ section.settings.autoplay_delay | default: 5000 }},
            disableOnInteraction: false,
          },
        {% endif %}
        {% if section.settings.show_pagination %}
          pagination: {
            el: '.text-content__reviews-{{ section_id }} .swiper-pagination',
            clickable: true,
          },
        {% endif %}
        {% if section.settings.show_navigation %}
          navigation: {
            nextEl: '.text-content__reviews-{{ section_id }} .swiper-button-next',
            prevEl: '.text-content__reviews-{{ section_id }} .swiper-button-prev',
          },
        {% endif %}
      };
      
      // Configuration for image slider (slave but with controls on mobile)
      const imageConfig = {
        slidesPerView: 1,
        spaceBetween: 20,
        loop: {{ section.settings.enable_loop }},
        effect: 'fade',
        grabCursor: false,
        fadeEffect: {
          crossFade: true
        },
        allowTouchMove: true,
        {% if section.settings.show_pagination %}
          pagination: {
            el: '.image-content__reviews-{{ section_id }} .swiper-pagination',
            clickable: true,
          },
        {% endif %}
        {% if section.settings.show_navigation %}
          navigation: {
            nextEl: '.image-content__reviews-{{ section_id }} .swiper-button-next',
            prevEl: '.image-content__reviews-{{ section_id }} .swiper-button-prev',
          },
        {% endif %}
        breakpoints: {
          992: {
            allowTouchMove: false,
          }
        }
      };
      
      // Set configs
      textSlider.config = textConfig;
      imageSlider.config = imageConfig;
      
      // Wait for both sliders to initialize, then sync them
      setTimeout(() => {
        const textSwiperInstance = textSlider.swiperInstance;
        const imageSwiperInstance = imageSlider.swiperInstance;
        
        if (textSwiperInstance && imageSwiperInstance) {
          // Sync image slider when text slider changes
          textSwiperInstance.on('slideChange', function() {
            if (!isImageSliderChanging) {
              isTextSliderChanging = true;
              imageSwiperInstance.slideTo(this.realIndex);
              setTimeout(() => { isTextSliderChanging = false; }, 50);
            }
          });
          
          // Sync text slider when image slider changes (for mobile controls)
          imageSwiperInstance.on('slideChange', function() {
            if (!isTextSliderChanging) {
              isImageSliderChanging = true;
              textSwiperInstance.slideTo(this.realIndex);
              setTimeout(() => { isImageSliderChanging = false; }, 50);
            }
          });
          
          // Sync autoplay between both sliders
          textSwiperInstance.on('autoplayStart', function() {
            if (imageSwiperInstance.autoplay) {
              imageSwiperInstance.autoplay.start();
            }
          });
          
          textSwiperInstance.on('autoplayStop', function() {
            if (imageSwiperInstance.autoplay) {
              imageSwiperInstance.autoplay.stop();
            }
          });
        }
      }, 100);
    }
  });
</script>

{% schema %}
{
  "name": "Custom Reviews Swiper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SEE WHAT THE CHURPIN' IS ABOUT"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "t:general.settings.content_alignment.label",
      "default": "ta-left",
      "options": [
        {
          "value": "ta-left",
          "label": "t:general.settings.option_left.label"
        },
        {
          "value": "ta-center",
          "label": "t:general.settings.option_center.label"
        },
        {
          "value": "diagonal d-grid-md",
          "label": "t:general.settings.content_alignment.options.option_diagonal.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_view_all_button",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Reviews",
      "visible_if": "{{ section.settings.show_view_all_button == true }}"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "visible_if": "{{ section.settings.show_view_all_button == true }}"
    },
    {
      "type": "select",
      "id": "btn_type",
      "label": "Button type",
      "default": "btn-primary",
      "options": [
        {
          "value": "btn-primary",
          "label": "Primary Button"
        },
        {
          "value": "btn-secondary",
          "label": "Secondary Button"
        },
        {
          "value": "btn-link",
          "label": "Link"
        }
      ],
      "visible_if": "{{ section.settings.show_view_all_button == true }}"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "Autoplay delay (ms)",
      "min": 1000,
      "max": 9000,
      "step": 200,
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "remove_padding_top",
      "label": "t:general.settings.remove_padding_top.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "remove_padding_bottom",
      "label": "t:general.settings.remove_padding_bottom.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "review_image",
          "label": "Review Image",
          "info": "Optional image to display with the review"
        },
        {
          "type": "richtext",
          "id": "review_text",
          "label": "Review Text",
          "default": "<p>This product exceeded my expectations! Highly recommend.</p>"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Customer Name"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Reviews Swiper",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}
