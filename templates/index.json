    "image_with_text_columns_VpyiNK": {
      "type": "image-with-text-columns",
      "blocks": {
        "text_JaYRH9": {
          "type": "text",
          "settings": {
            "image": "shopify://shop_images/MADE_LOCAL.jpg",
            "heading": "MADE LOCAL",
            "description": "<p>Every Metalbird is made where it’s sold, supporting local makers, shrinking shipping miles, and keeping the craft (and jobs) close to home.</p><p><a href=\"/blogs/word-from-the-bird/made-local-made-sustainable-made-for-birds#made-local\" title=\"/blogs/word-from-the-bird/made-local-made-sustainable-made-for-birds#made-local\"><span style=\"text-decoration:underline\">read more</span></a></p>"
          }
        },
        "text_LHUqXD": {
          "type": "text",
          "settings": {
            "image": "shopify://shop_images/MADE_SUSTAINABLE.jpg",
            "heading": "Made Sustainable",
            "description": "<p>Crafted from Corten steel, designedto change with the weather but lastsa lifetime. Strong, simple, and quietlybeautiful, like the birds it honours.</p><p><a href=\"/blogs/word-from-the-bird/made-local-made-sustainable-made-for-birds#made-sustainable\" title=\"/blogs/word-from-the-bird/made-local-made-sustainable-made-for-birds#made-sustainable\"><span style=\"text-decoration:underline\">read more</span></a></p>"
          }
        },
        "text_NUWipV": {
          "type": "text",
          "settings": {
