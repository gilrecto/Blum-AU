<!doctype html>
<html class="{% if customer.b2b? %}mbau-wholesale {% endif %}no-js" lang="{{ request.locale.iso_code }}">
  <head>
    {%- if request.page_type == 'cart' -%}
      {%- unless customer.b2b? -%}
        <script async>
          window.location.href = "{{ settings.no_view_url }}";
        </script>
      {%- endunless -%}
    {%- endif -%}

    {%- render 'mb_marketing' -%}

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>
      {{ page_title }}
      {%- if current_tags -%}
        &ndash; tagged "{{ current_tags | join: ', ' }}"
      {%- endif -%}
      {%- if current_page != 1 -%}
        &ndash; Page {{ current_page }}
      {%- endif -%}
      {%- unless page_title contains shop.name -%}
        &ndash; {{ shop.name }}
      {%- endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'fb-open-graph-tags' %}
    {%- render 'twitter-card' -%}

    {% render 'meta-tags' %}
    {% render 'style-variables' %}

    {% comment %} {{ content_for_header }} {% endcomment %}
    {%- if request.design_mode or template contains 'cart' or template contains 'checkout' -%}
      {{ content_for_header }}
    {%- else -%}
      {% render 'header_content_optimized' %}
    {%- endif -%}

    {% render 'theme_styles' %}
    {%- render 'color-swatch-data' -%}
    {% render 'head_scripts' %}
    {%- render 'custom-css' -%}
    {%- liquid
      render 'vite-tag' with 'main.css'
      render 'vite-tag' with 'main.js'
    -%}
    {{ shop.metafields.loox.global_html_head }}
  </head>

  <body
    class="js-main-body background template-{{ request.page_type }}{% if settings.enable_menu_item_uppercase %} menu-item--uppercase{% endif %}{% if template.suffix != blank %} template__{{ template.suffix }}{% else %} template__default--{{ request.page_type }}{% endif %}"
    data-cart-show-type="{{ settings.add_to_cart_confirmation }}"
    data-cart-type="{{ settings.cart_type }}"
  >
    <a class="visually-hidden skip-to-content btn btn-primary d-block ta-center" href="#mainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    {%- liquid
      sections 'header-group'
    -%}
    <script>
      let SHTHeaderParent = SHTHelper.qs('.js-section-header');
      let SHTAnnouncement = SHTHelper.qs('.js-anmb-section');
      let SHTResizeBodyObserver = new ResizeObserver((entries) => {
        let SHTHeaderObj = SHTHelper.qs('sht-header');
        SHTHelper.qde.style.setProperty(
          '--header-height',
          SHTHeaderObj ? `${Math.ceil(SHTHeaderObj.getBoundingClientRect().height)}px` : '0px'
        );
        SHTHelper.qde.style.setProperty(
          '--header-offset-top',
          SHTHeaderParent ? `${Math.ceil(SHTHeaderParent.getBoundingClientRect().top)}px` : '0px'
        );
        SHTHelper.qde.style.setProperty(
          '--anno-height',
          SHTAnnouncement ? `${Math.ceil(SHTAnnouncement.getBoundingClientRect().height)}px` : '0px'
        );
      });
      SHTResizeBodyObserver.observe(SHTHelper.qs('body'));
    </script>
    <main id="mainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
      <script>
        /*include_js_style_tag*/
      </script>
    </main>
    {%- liquid
      sections 'footer-group'
      section 'popup'
      render 'quickshop'
    -%}
    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>
    <script id="theme-file-js" src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
    {%- if settings.product_rating_app == 'judge_me' -%}
      <script src="{{ 'component-rating.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if request.design_mode -%}
      <script src="{{ 'editor.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if request.design_mode == false and settings.preload_links_on_hover -%}
      <script src="{{ 'library-instant-page.js' | asset_url }}" type="module" defer="defer"></script>
    {%- endif -%}
    <link rel="stylesheet" href="{{ 'animation.css' | asset_url }}" media="print" onload="this.media='all'">

    {%- capture loox_optimized -%}
    	{{ shop.metafields.loox["global_html_body"] | replace: 'async', 'type="lazyload2" async', | replace: "src=", "data-src=" }}
    {%- endcapture -%}

    {{ loox_optimized }}
    {%- render 'klaviyo_onsite_integration' -%}

    <script type="lazyload2" data-src="{{ 'fbqSearchKeyword.js' | asset_url }}"></script>
    
    
    {%- unless customer.b2b? -%}
      {%- render 'mb_tab_title_change' -%}
      {%- render 'mb-geolocation' -%}
  
      {%- if settings.fmw_enable and settings.fmw_products != blank -%}
        {% render 'mb_freemini_popup' %}
        <script type="lazyload2" data-src="{{ 'component_free_mini_selector.js' | asset_url }}"></script>
      {%- endif -%}
    {%- endunless -%}
  </body>
</html>

{%- render 'optimization_script' -%}